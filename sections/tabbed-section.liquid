{%- comment -%}
  Section: Quick Info Tabs
  Each block is a lightweight reference to one 'tabs' metaobject entry.
  Add/remove/reorder blocks in the theme editor to control which tabs
  appear and in what order for this specific section instance.
  Fields on the 'tabs' metaobject type:
    title         (single_line_text_field)
    color         (color)
    icon          (file_reference — image)
    content       (rich_text_field)
    second_column (rich_text_field, optional)
    panel_image   (file_reference — image, optional)
{%- endcomment -%}

<div class="qi" id="qi-{{ section.id }}">

  {%- comment -%} Centered icon-button tab nav {%- endcomment -%}
  <div class="qi__nav" role="tablist" aria-label="Info tabs">
    {%- for block in section.blocks -%}
      {%- assign tab = block.settings.tab_ref -%}
      {%- if tab == blank -%}{%- continue -%}{%- endif -%}
      {%- assign btn_color = tab.color.value | default: '#EB0D8B' -%}
      {%- assign btn_shadow = btn_color | color_darken: 22 -%}
      <button
        class="qi__btn{% if forloop.first %} is-active{% endif %}"
        role="tab"
        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        aria-controls="qi-panel-{{ section.id }}-{{ forloop.index }}"
        id="qi-tab-{{ section.id }}-{{ forloop.index }}"
        data-tab-index="{{ forloop.index0 }}"
        style="--c: {{ btn_color }}; --cs: {{ btn_shadow }};"
        {{ block.shopify_attributes }}
      >
        <span class="qi__icon-wrap">
          {%- if tab.icon.value != blank -%}
            <img
              class="qi__icon-img"
              src="{{ tab.icon.value | image_url: width: 160 }}"
              alt=""
              loading="lazy"
              width="70"
              height="70"
            >
          {%- else -%}
            <svg class="qi__icon-fallback" viewBox="0 0 48 52" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="8" y1="9" x2="3" y2="2" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <line x1="15" y1="7" x2="12" y2="1" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <rect x="3" y="8" width="26" height="28" rx="7" fill="currentColor" opacity="0.85"/>
              <rect x="13" y="4" width="9" height="32" rx="4.5" fill="currentColor"/>
              <circle cx="11" cy="41" r="8.5" fill="currentColor" opacity="0.85"/>
              <circle cx="30" cy="41" r="8.5" fill="currentColor" opacity="0.85"/>
              <circle cx="8" cy="39.5" r="2.5" fill="white"/>
              <circle cx="27" cy="39.5" r="2.5" fill="white"/>
            </svg>
          {%- endif -%}
        </span>
        <span class="qi__btn-label">{{ tab.title.value }}</span>
      </button>
    {%- else -%}
      <p class="qi__empty">Add tabs using the <em>+</em> button in the theme editor.</p>
    {%- endfor -%}
  </div>

  {%- comment -%} Tab panels {%- endcomment -%}
  <div class="qi__panels">
    {%- for block in section.blocks -%}
      {%- assign tab = block.settings.tab_ref -%}
      {%- if tab == blank -%}{%- continue -%}{%- endif -%}
      {%- assign has_panel_image = false -%}
      {%- if tab.panel_image.value != blank -%}{%- assign has_panel_image = true -%}{%- endif -%}
      {%- assign has_two_col = false -%}
      {%- if tab.second_column != blank -%}{%- assign has_two_col = true -%}{%- endif -%}
      {%- assign panel_color = tab.color.value | default: '#EB0D8B' -%}
      <div
        class="qi__panel{% if forloop.first %} is-active{% endif %}"
        role="tabpanel"
        id="qi-panel-{{ section.id }}-{{ forloop.index }}"
        aria-labelledby="qi-tab-{{ section.id }}-{{ forloop.index }}"
        style="--c: {{ panel_color }};"
        {% unless forloop.first %}hidden{% endunless %}
      >
        <div class="qi__panel-inner{% if has_panel_image %} qi__panel-inner--with-image{% endif %}">

          {%- if has_panel_image -%}
            <div class="qi__panel-image">
              <img
                src="{{ tab.panel_image.value | image_url: width: 600 }}"
                alt="{{ tab.title.value }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}

          <div class="qi__panel-text{% if has_two_col %} qi__panel-text--two-col{% endif %}">
            <div class="qi__col">
              {%- if tab.title.value != blank -%}
                <h3 class="qi__heading">{{ tab.title.value }}</h3>
              {%- endif -%}
              <div class="qi__content">{{ tab.content | metafield_tag }}</div>
            </div>
            {%- if has_two_col -%}
              <div class="qi__col">
                <div class="qi__content">{{ tab.second_column | metafield_tag }}</div>
              </div>
            {%- endif -%}
          </div>

        </div>
      </div>
    {%- endfor -%}
  </div>

</div>

<script>
(function () {
  var root = document.getElementById('qi-{{ section.id }}');
  if (!root) return;
  var btns   = root.querySelectorAll('.qi__btn');
  var panels = root.querySelectorAll('.qi__panel');

  btns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var idx = parseInt(btn.dataset.tabIndex, 10);
      btns.forEach(function (b, i) {
        b.classList.toggle('is-active', i === idx);
        b.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
      panels.forEach(function (p, i) {
        p.classList.toggle('is-active', i === idx);
        if (i === idx) { p.removeAttribute('hidden'); }
        else           { p.setAttribute('hidden', ''); }
      });
    });

    btn.addEventListener('keydown', function (e) {
      var cur = parseInt(btn.dataset.tabIndex, 10);
      var next;
      if      (e.key === 'ArrowRight') { next = (cur + 1) % btns.length; }
      else if (e.key === 'ArrowLeft')  { next = (cur - 1 + btns.length) % btns.length; }
      else { return; }
      e.preventDefault();
      btns[next].click();
      btns[next].focus();
    });
  });
})();
</script>

{% style %}

/* ── Outer wrapper ── */
.qi {
  padding: {{ section.settings.padding_top }}px {{ section.settings.padding_sides }}px {{ section.settings.padding_bottom }}px;
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  font-family: var(--font-body--family, sans-serif);
  color: var(--color-foreground, #222);
}

/* ── Desktop: side-by-side (nav left, panel right) ── */
@media screen and (min-width: 641px) {
  .qi {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }
  .qi__panels {
    flex: 1;
    min-width: 0;
  }
}

/* ── Tab nav ── */
.qi__nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.75rem 1.25rem;
  margin-bottom: 1.25rem;
}

@media screen and (min-width: 641px) {
  .qi__nav {
    flex-direction: column;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: 0.3rem;
    margin-bottom: 0;
    flex-shrink: 0;
    width: 130px;
  }
}

/* ── Individual tab button ── */
.qi__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  font-family: inherit;
  transition: transform 0.2s ease;
  -webkit-tap-highlight-color: transparent;
}

.qi__btn:hover     { transform: translateY(-3px); }
.qi__btn.is-active { transform: translateY(-3px); }

/* Desktop: horizontal button row */
@media screen and (min-width: 641px) {
  .qi__btn {
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0.5rem;
    border-radius: 12px;
    text-align: left;
    transition: background 0.2s ease;
  }
  .qi__btn:hover     { transform: none; }
  .qi__btn.is-active { transform: none; }
  .qi__btn.is-active {
    background: color-mix(in srgb, var(--c) 8%, transparent);
  }
}

/* ── Icon container ── */
.qi__icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68px;
  height: 74px;
  border-radius: 17px;
  background: rgba(0, 0, 0, 0.06);
  filter: grayscale(1);
  opacity: 0.45;
  transition: background 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease, opacity 0.2s ease;
  overflow: hidden;
  flex-shrink: 0;
}

.qi__btn:hover .qi__icon-wrap {
  background: color-mix(in srgb, var(--c) 18%, white);
  filter: grayscale(0.2);
  opacity: 0.75;
}

.qi__btn.is-active .qi__icon-wrap {
  background: var(--c);
  filter: none;
  opacity: 1;
  box-shadow: 4px 4px 0 0 var(--cs);
}

/* Desktop: slightly smaller icon */
@media screen and (min-width: 641px) {
  .qi__icon-wrap {
    width: 48px;
    height: 52px;
    border-radius: 13px;
  }
}

/* ── Icon image ── */
.qi__icon-img {
  width: 52px;
  height: 52px;
  object-fit: contain;
  object-position: center;
}

@media screen and (min-width: 641px) {
  .qi__icon-img { width: 38px; height: 38px; }
}

/* ── Fallback SVG ── */
.qi__icon-fallback                    { width: 36px; height: 36px; color: #666; }
.qi__btn.is-active .qi__icon-fallback { color: white; }

@media screen and (min-width: 641px) {
  .qi__icon-fallback { width: 28px; height: 28px; }
}

/* ── Tab label ── */
.qi__btn-label {
  font-size: 0.78rem;
  font-weight: 700;
  color: #aaa;
  text-align: center;
  max-width: 80px;
  line-height: 1.2;
  transition: color 0.2s ease;
}

.qi__btn:hover    .qi__btn-label { color: #666; }
.qi__btn.is-active .qi__btn-label { color: var(--c); }

@media screen and (min-width: 641px) {
  .qi__btn-label {
    font-size: 0.82rem;
    text-align: left;
    max-width: none;
  }
}

/* ── Empty state ── */
.qi__empty {
  opacity: 0.55;
  font-size: 0.875rem;
}

/* ── Panels ── */
.qi__panel { display: none; }

.qi__panel.is-active {
  display: block;
  animation: qi-fade 0.2s ease;
}

@keyframes qi-fade {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Panel inner ── */
.qi__panel-inner { }

.qi__panel-inner--with-image {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
}

.qi__panel-image img {
  width: 180px;
  flex-shrink: 0;
  border-radius: 12px;
  object-fit: cover;
}

.qi__panel-text { flex: 1; min-width: 0; }

/* ── Two-column text layout ── */
.qi__panel-text--two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.75rem;
}

/* ── Heading — colored to match active tab ── */
.qi__heading {
  margin: 0 0 0.4rem;
  font-size: 0.95rem;
  font-weight: 700;
  line-height: 1.25;
  color: var(--c);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

/* ── Rich text content ── */
.qi__content {
  font-size: 0.9rem;
  line-height: 1.55;
  color: #444;
}

.qi__content p            { margin: 0 0 0.4rem; }
.qi__content p:last-child { margin-bottom: 0; }
.qi__content ul,
.qi__content ol           { padding-left: 1.2rem; margin: 0 0 0.4rem; }
.qi__content li           { margin-bottom: 0.2rem; }
.qi__content strong       { font-weight: 700; }

/* Override theme heading sizes inside richtext — keep compact */
.qi__content h1,
.qi__content h2,
.qi__content h3,
.qi__content h4 {
  font-size: 0.95rem;
  font-weight: 700;
  line-height: 1.25;
  margin: 0 0 0.35rem;
  color: inherit;
}

/* ── Mobile ── */
@media screen and (max-width: 640px) {
  .qi__icon-wrap  { width: 60px; height: 65px; border-radius: 15px; }
  .qi__icon-img   { width: 44px; height: 44px; }
  .qi__icon-fallback { width: 30px; height: 30px; }

  .qi__panel-inner--with-image { flex-direction: column; }
  .qi__panel-image img         { width: 100%; }
  .qi__panel-text--two-col     { grid-template-columns: 1fr; gap: 1rem; }
}
{% endstyle %}

{% schema %}
{
  "name": "Quick Info Tabs",
  "tag": "section",
  "class": "section-quick-info-tabs",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 400,
      "max": 1400,
      "step": 20,
      "default": 900
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_sides",
      "label": "Padding sides (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "metaobject",
          "id": "tab_ref",
          "label": "Tab",
          "metaobject_type": "tabs"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick Info Tabs"
    }
  ]
}
{% endschema %}
