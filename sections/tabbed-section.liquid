{%- comment -%}
  Section: Quick Info Tabs
  Redesigned: open integrated layout, chunky brand-aligned icon buttons,
  optional two-column content and optional panel image per tab.
{%- endcomment -%}

<div class="qi" id="qi-{{ section.id }}">

  {%- comment -%} Centered icon-button tab nav {%- endcomment -%}
  <div class="qi__nav" role="tablist" aria-label="Info tabs">
    {%- for block in section.blocks -%}
      {%- assign btn_color = block.settings.color | default: '#EB0D8B' -%}
      {%- assign btn_shadow = btn_color | color_darken: 22 -%}
      <button
        class="qi__btn{% if forloop.first %} is-active{% endif %}"
        role="tab"
        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        aria-controls="qi-panel-{{ block.id }}"
        id="qi-tab-{{ block.id }}"
        data-tab-index="{{ forloop.index0 }}"
        style="--c: {{ btn_color }}; --cs: {{ btn_shadow }};"
        {{ block.shopify_attributes }}
      >
        <span class="qi__icon-wrap">
          {%- if block.settings.icon_image != blank -%}
            <img
              class="qi__icon-img"
              src="{{ block.settings.icon_image | image_url: width: 160 }}"
              alt=""
              loading="lazy"
              width="70"
              height="70"
            >
          {%- else -%}
            {%- comment -%} Fallback: Doodle Bug logo-mark style SVG {%- endcomment -%}
            <svg class="qi__icon-fallback" viewBox="0 0 48 52" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="8" y1="9" x2="3" y2="2" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <line x1="15" y1="7" x2="12" y2="1" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <rect x="3" y="8" width="26" height="28" rx="7" fill="currentColor" opacity="0.85"/>
              <rect x="13" y="4" width="9" height="32" rx="4.5" fill="currentColor"/>
              <circle cx="11" cy="41" r="8.5" fill="currentColor" opacity="0.85"/>
              <circle cx="30" cy="41" r="8.5" fill="currentColor" opacity="0.85"/>
              <circle cx="8" cy="39.5" r="2.5" fill="white"/>
              <circle cx="27" cy="39.5" r="2.5" fill="white"/>
            </svg>
          {%- endif -%}
        </span>
        <span class="qi__btn-label">{{ block.settings.tab_title }}</span>
      </button>
    {%- endfor -%}
  </div>

  {%- comment -%} Tab panels {%- endcomment -%}
  <div class="qi__panels">
    {%- for block in section.blocks -%}
      {%- assign has_panel_image = false -%}
      {%- if block.settings.panel_image != blank -%}{%- assign has_panel_image = true -%}{%- endif -%}
      {%- assign has_two_col = false -%}
      {%- if block.settings.second_column != blank -%}{%- assign has_two_col = true -%}{%- endif -%}
      <div
        class="qi__panel{% if forloop.first %} is-active{% endif %}"
        role="tabpanel"
        id="qi-panel-{{ block.id }}"
        aria-labelledby="qi-tab-{{ block.id }}"
        {% unless forloop.first %}hidden{% endunless %}
      >
        <div class="qi__panel-inner{% if has_panel_image %} qi__panel-inner--with-image{% endif %}">

          {%- if has_panel_image -%}
            <div class="qi__panel-image">
              <img
                src="{{ block.settings.panel_image | image_url: width: 600 }}"
                alt="{{ block.settings.heading }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}

          <div class="qi__panel-text{% if has_two_col %} qi__panel-text--two-col{% endif %}">
            <div class="qi__col">
              {%- if block.settings.heading != blank -%}
                <h3 class="qi__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              <div class="qi__content">{{ block.settings.content }}</div>
              {%- if block.settings.button_text != blank and block.settings.button_link != blank -%}
                <a href="{{ block.settings.button_link }}" class="qi__cta">{{ block.settings.button_text }}</a>
              {%- endif -%}
            </div>
            {%- if has_two_col -%}
              <div class="qi__col">
                <div class="qi__content">{{ block.settings.second_column }}</div>
              </div>
            {%- endif -%}
          </div>

        </div>
      </div>
    {%- endfor -%}
  </div>

</div>

<script>
(function () {
  var root = document.getElementById('qi-{{ section.id }}');
  if (!root) return;
  var btns   = root.querySelectorAll('.qi__btn');
  var panels = root.querySelectorAll('.qi__panel');

  btns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var idx = parseInt(btn.dataset.tabIndex, 10);
      btns.forEach(function (b, i) {
        b.classList.toggle('is-active', i === idx);
        b.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
      panels.forEach(function (p, i) {
        p.classList.toggle('is-active', i === idx);
        if (i === idx) { p.removeAttribute('hidden'); }
        else           { p.setAttribute('hidden', ''); }
      });
    });

    btn.addEventListener('keydown', function (e) {
      var cur = parseInt(btn.dataset.tabIndex, 10);
      var next;
      if      (e.key === 'ArrowRight') { next = (cur + 1) % btns.length; }
      else if (e.key === 'ArrowLeft')  { next = (cur - 1 + btns.length) % btns.length; }
      else { return; }
      e.preventDefault();
      btns[next].click();
      btns[next].focus();
    });
  });
})();
</script>

{% style %}

/* ── Outer wrapper ── */
.qi {
  padding: {{ section.settings.padding_top }}px {{ section.settings.padding_sides }}px {{ section.settings.padding_bottom }}px;
  font-family: var(--font-body--family, sans-serif);
  color: var(--color-foreground, #222);
}

/* ── Tab nav ── */
.qi__nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.75rem 2.5rem;
  margin-bottom: 2.5rem;
}

/* ── Individual tab button ── */
.qi__btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  font-family: inherit;
  transition: transform 0.2s ease;
  -webkit-tap-highlight-color: transparent;
}

.qi__btn:hover {
  transform: translateY(-4px);
}

.qi__btn.is-active {
  transform: translateY(-4px);
}

/* ── Icon container — chunky rounded-square (Doodle Bug mark shape) ── */
.qi__icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88px;
  height: 96px;
  border-radius: 22px;
  background: color-mix(in srgb, var(--c) 14%, white);
  transition: background 0.2s ease, box-shadow 0.2s ease;
  overflow: hidden;
}

.qi__btn:hover .qi__icon-wrap {
  background: color-mix(in srgb, var(--c) 24%, white);
}

.qi__btn.is-active .qi__icon-wrap {
  background: var(--c);
  box-shadow: 5px 5px 0 0 var(--cs);
}

/* ── Icon image (uploaded) ── */
.qi__icon-img {
  width: 66px;
  height: 66px;
  object-fit: contain;
  object-position: center;
}

/* ── Fallback SVG ── */
.qi__icon-fallback {
  width: 46px;
  height: 46px;
  color: var(--c);
}

.qi__btn.is-active .qi__icon-fallback {
  color: white;
}

/* ── Tab label ── */
.qi__btn-label {
  font-size: 0.875rem;
  font-weight: 700;
  color: #555;
  text-align: center;
  max-width: 100px;
  line-height: 1.2;
  transition: color 0.2s ease;
}

.qi__btn.is-active .qi__btn-label {
  color: var(--c);
}

/* ── Panels ── */
.qi__panel {
  display: none;
}

.qi__panel.is-active {
  display: block;
  animation: qi-fade 0.25s ease;
}

@keyframes qi-fade {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Panel inner: optional side image layout ── */
.qi__panel-inner--with-image {
  display: flex;
  gap: 2.5rem;
  align-items: flex-start;
}

.qi__panel-image img {
  width: 220px;
  flex-shrink: 0;
  border-radius: 18px;
  object-fit: cover;
}

.qi__panel-text {
  flex: 1;
  min-width: 0;
}

/* ── Two-column text layout ── */
.qi__panel-text--two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2.5rem;
}

/* ── Heading ── */
.qi__heading {
  margin: 0 0 0.75rem;
  font-size: 1.35rem;
  font-weight: 700;
  line-height: 1.25;
}

/* ── Rich text content ── */
.qi__content {
  font-size: 0.9875rem;
  line-height: 1.75;
  color: #444;
}

.qi__content p             { margin: 0 0 0.75rem; }
.qi__content p:last-child  { margin-bottom: 0; }
.qi__content ul,
.qi__content ol            { padding-left: 1.5rem; margin: 0 0 0.75rem; }
.qi__content li            { margin-bottom: 0.35rem; }
.qi__content strong        { font-weight: 700; }

/* ── CTA button ── */
.qi__cta {
  display: inline-block;
  margin-top: 1.25rem;
  padding: 0.6rem 1.5rem;
  background: var(--color-primary, #EB0D8B);
  color: #fff;
  font-weight: 700;
  font-size: 0.875rem;
  text-decoration: none;
  border-radius: 30px;
  transition: opacity 0.2s ease;
}

.qi__cta:hover {
  opacity: 0.85;
}

/* ── Mobile ── */
@media screen and (max-width: 640px) {
  .qi__nav {
    gap: 1.25rem 1.75rem;
    margin-bottom: 2rem;
  }

  .qi__icon-wrap {
    width: 72px;
    height: 80px;
    border-radius: 18px;
  }

  .qi__icon-img {
    width: 54px;
    height: 54px;
  }

  .qi__icon-fallback {
    width: 38px;
    height: 38px;
  }

  .qi__btn-label {
    font-size: 0.8rem;
    max-width: 80px;
  }

  .qi__panel-inner--with-image {
    flex-direction: column;
  }

  .qi__panel-image img {
    width: 100%;
  }

  .qi__panel-text--two-col {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Quick Info Tabs",
  "tag": "section",
  "class": "section-quick-info-tabs",
  "settings": [
    {
      "type": "header",
