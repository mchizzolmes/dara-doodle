      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_sides",
      "label": "Padding sides (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab label",
          "default": "Tab"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Tab color",
          "default": "#EB0D8B"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "header",
          "content": "Panel content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content (first column)",
          "default": "<p>Add your content here.</p>"
        },
        {
          "type": "richtext",
